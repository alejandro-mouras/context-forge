# Python
.venv/
__pycache__/
*.pyc

# Environment & config (contain user-specific values)
.env
/config.yaml
.claude/settings.local.json

# Feature profiles (project-specific, not committed)
features/*.yaml

# Input data (user-provided)
input/audio/*
input/video/*
input/docs/*
input/text/*

# Processing intermediates (generated by pipeline)
processing/*


# Output (generated by pipeline)
output/

# OS
.DS_Store

# Keep directory structure
!input/audio/.gitkeep
!input/video/.gitkeep
!input/docs/.gitkeep
!input/text/.gitkeep
!processing/normalized/.gitkeep
!processing/summarized/.gitkeep
!features/README.md

# Claude
.claude/